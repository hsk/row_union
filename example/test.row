let rec ev x =
      match x with
      | Add(l, r) -> ev l + ev r
      | i:Int -> i
let rec ev2 x =
      match x with
      | Add(Add(l1, r1), r) -> ev2 l1 + ev2 r1 + ev2 r
      | i:Int -> i
let rec ev3 x =
      match x with
      | i:Int -> i
      | default -> true
let v = 1
let v = Add(Mul(2,1),3)
let v = ev (Add(Add(1,2),Add(3,4)))
